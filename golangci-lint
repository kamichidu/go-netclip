#!/bin/bash
set -euo pipefail

install-golangci-lint() {
    local target_dir="${1}"
    local version="2.12.2"
    
    local os
    os="$(uname -s | tr '[:upper:]' '[:lower:]')"
    local arch
    arch="$(uname -m)"
    if [[ "${arch}" == "x86_64" ]]; then
        arch="amd64"
    fi

    local url="https://github.com/golangci/golangci-lint/releases/download/v${version}/golangci-lint-${version}-${os}-${arch}.tar.gz"
    
    printf "Installing golangci-lint v%s...\n" "${version}" >&2
    mkdir -p "${target_dir}"
    curl -sSfL "${url}" | tar -xz -C "${target_dir}" --strip-components=1 "golangci-lint-${version}-${os}-${arch}/golangci-lint"
}

main() {
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local local_bin="${script_dir}/.local/bin"
    local bin_path="${local_bin}/golangci-lint"

    if [[ ! -x "${bin_path}" ]]; then
        install-golangci-lint "${local_bin}"
    fi

    exec "${bin_path}" "$@"
}

main "$@"
